+function maybeDownscale(img) {
+  const longest = Math.max(img.naturalWidth, img.naturalHeight);
+  if (longest <= CONFIG.MAX_UPLOAD_PX) {
+    return { source: img, w: img.naturalWidth, h: img.naturalHeight };
