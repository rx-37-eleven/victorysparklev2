<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comic+Neue:wght@400;700&family=DynaPuff:wght@500&family=Miniver&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon.png">
    <title>{% if title %}{{ title }} · {% endif %}Victory Sparkle Co.</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <div class="header-content">
            <a href="/" class="logo-section" aria-label="Victory Sparkle Co. home">
                <div class="profile-image"><img src="/images/Vlogo.png" alt=""></div>
                <div class="site-title">Victory Sparkle Co.</div>
            </a>
            <nav class="main-nav">
                <div class="nav-item">
                    <button type="button" class="nav-trigger" aria-expanded="false">Make</button>
                    <div class="nav-dropdown">
                        <a href="/apps/pinpress/">Pinpress</a>
                        <a href="/resources/">Resources</a>
                        <a href="https://www.pinterest.com/victorysparkle/website-board/" target="_blank" rel="noopener noreferrer">Pinterest</a>
                    </div>
                </div>
                <div class="nav-item">
                    <button type="button" class="nav-trigger" aria-expanded="false">Code</button>
                    <div class="nav-dropdown">
                        <a href="/#coding-projects">Telegram Bots</a>
                    </div>
                </div>
                <div class="nav-item">
                    <button type="button" class="nav-trigger" aria-expanded="false">Enjoy</button>
                    <div class="nav-dropdown">
                        <span class="nav-placeholder">Coming soon</span>
                    </div>
                </div>
                <div class="nav-item">
                    <button type="button" class="nav-trigger" aria-expanded="false">Contact</button>
                    <div class="nav-dropdown">
                        <a href="/blog/">Blog</a>
                        <a href="/map/">Travel Map</a>
                        <a href="/contact/">Contact</a>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <div class="footer-content">
            <p>&copy; 2025 Victory Sparkle Co. All rights reserved.</p>
            <div class="footer-links">
                <a href="/apps/pinpress/">Pinpress</a>
                <a href="/#coding-projects">Telegram Bots</a>
                <a href="/resources/">Resources</a>
                <a href="/map/">Travel Map</a>
                <a href="/blog/">Blog</a>
                <a href="/contact/">Contact</a>
            </div>
            <div><br> <p><em>Semper Desiderari, Princess Sandy</em></p></div>
        </div>
    </footer>
    <script async defer src="//assets.pinterest.com/js/pinit.js"></script>
    <script src="/js/nav.js" defer></script>
</body>
</html>
